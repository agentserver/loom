# prod_test tree holds OAuth creds, sqlite state, locally-rebuilt binaries —
# all ignored. Use the per-entry negations below to whitelist repo docs.
# (Pattern note: `/tests/prod_test/*` not `/tests/prod_test/` — git ignores
# negation patterns for files inside a fully-ignored directory.)
/tests/prod_test/*
!/tests/prod_test/README.md
!/tests/prod_test/E2E_RUNBOOK.md
!/tests/prod_test/run_e2e.sh
!/tests/prod_test/driver_mcp_e2e.py
tests/claude_driver/.mcp.json
