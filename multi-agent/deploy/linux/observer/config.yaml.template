listen_addr: "__LISTEN_ADDR__"
db_path: __LOOM_HOME__/observer.db

# Workspaces are the units other agents register against. Each workspace's
# api_keys[] entries are shared bootstrap keys: slaves and drivers POST one
# of them as Bearer on /api/agents/register to mint a per-agent token.
# Add more workspaces (or more api_keys per workspace) by hand after install.
workspaces:
  - id: __WORKSPACE_ID__
    name: __WORKSPACE_NAME__
    api_keys:
      - id: bootstrap
        key: "__WS_APIKEY__"
