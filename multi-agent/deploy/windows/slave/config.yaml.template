server:
  url: "https://agent.cs.ac.cn"
  name: __AGENT_NAME__

credentials:
  sandbox_id: ""
  tunnel_token: ""
  proxy_token: ""
  workspace_id: ""
  short_id: ""

agent:
  kind: __AGENT_KIND__

claude:
  bin: "claude"
  workdir: __LOOM_HOME__
  extra_args: []

codex:
  bin: "codex"
  workdir: __LOOM_HOME__
  extra_args: []

mcp_servers: {}

discovery:
  display_name: __AGENT_NAME__
  description: __DESCRIPTION__
  skills:
__SKILLS__

planner:
  bin: ""
  timeout_sec: 300
  extra_args: []

fanout:
  max_concurrency: 1
  default_policy: "best_effort"
  policy_by_skill: {}
  subtask_defaults:
    timeout_sec: 600
    max_budget_usd: 0

resources:
  cpu:
    cores: __CPU_CORES__
    arch: "amd64"
  memory_gb: __MEMORY_GB__
  tags:
    - "windows"
    - "windows-amd64"
    - "powershell"

observer:
  enabled: false
  telemetry_enabled: false
  url: __OBSERVER_URL__
  workspace_id: __WORKSPACE_ID__
  agent_id: __AGENT_NAME__
  api_key: __API_KEY__
  token_state_path: __TOKEN_STATE_PATH__
